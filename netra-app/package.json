{
  "name": "netra-gateway",
  "version": "1.0.0",
  "description": "Netra Gateway - AAA Server in Your Pocket",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --enable-logging",
    "build": "electron-builder --win",
    "backend": "cd ../netra-backend && npm start",
    "install-all": "npm install && cd ../netra-backend && npm install"
  },
  "author": "Netra Team",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "electron-log": "^5.0.0",
    "axios": "^1.6.0",
    "node-notifier": "^10.0.1"
  },
  "build": {
    "appId": "com.netra.gateway",
    "productName": "Netra Gateway",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "portable",
      "icon": "assets/icon.ico"
    },
    "files": [
      "src/**/*",
      "assets/**/*"
    ]
  }
}
